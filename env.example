# Environment Configuration — Discovery Mad-Libs
# Copy to .env and fill in your keys. This file is gitignored.

# ─── LLM Providers ───

# DeepInfra (multiple models, pay-per-use)
DEEPINFRA_API_KEY=your_key_here
DEEPINFRA_URL=https://api.deepinfra.com/v1/openai/chat/completions

# Groq (fast, cheap, compound models)
GROQ_API_KEY=your_key_here
GROQ_URL=https://api.groq.com/openai/v1/chat/completions

# OpenAI (GPT-4, etc.)
OPENAI_API_KEY=
OPENAI_URL=https://api.openai.com/v1/chat/completions

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_URL=https://api.anthropic.com/v1/messages

# ZAI / GLM
ZAI_API_KEY=
ZAI_URL=

# ─── Model Registry ───
# Format: provider/model_id | alias

[models]
# Fast and cheap (use for iteration)
fast = groq/compound-beta-mini
quick = deepinfra/meta-llama/Llama-3.3-70B-Instruct-Turbo

# Quality (use for final evaluation)
quality = deepinfra/deepseek-ai/DeepSeek-V3-0324
smart = deepinfra/Qwen/Qwen3-235B-A22B

# Specialized
code = deepinfra/deepseek-ai/DeepSeek-V3-0324
creative = deepinfra/Qwen/Qwen3-235B-A22B
evaluator = deepinfra/meta-llama/Llama-3.3-70B-Instruct-Turbo

# ─── GPU ───

CUDA_ARCH=sm_86
GPU_TIMEOUT=120

# ─── Lighthouse Keeper (optional) ───
# If a lighthouse keeper is on the network, keys can be fetched dynamically
# instead of stored locally. The keeper authenticates the discovery engine.

KEEPER_URL=
KEEPER_TOKEN=
# KEEPER_MODE=proxy means all LLM calls go through the keeper
KEEPER_MODE=local

# ─── Session ───

DEFAULT_ITERATIONS=10
AUTO_STOP_ON_DRIFT=true
SAVE_RAW_LLM_OUTPUT=true
